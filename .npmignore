# Files to exclude from npm package
# Using "files" whitelist in package.json instead is preferred
# This is a backup safety net

# Source control
.git/
.github/
.gitignore

# Development files
.reshot/
reshot.config.json
reshot.config.example.json
*.log

# Environment and secrets
.env
.env.*
*.local

# IDE and editor
.vscode/
.idea/
*.swp
*.swo
*~

# Build artifacts and caches
node_modules/
.cache/
coverage/
.nyc_output/
*.tsbuildinfo

# Package manager lock files (users will regenerate)
pnpm-lock.yaml
package-lock.json
yarn.lock

# Testing
tests/
__tests__/
*.test.js
*.spec.js

# Documentation source (keep compiled)
docs/

# Misc
*.md.bak
*.tmp
*.temp
.DS_Store
Thumbs.db

# Web manager source (only include dist)
web/manager/src/
web/manager/node_modules/
web/manager/.reshot/
web/manager/pnpm-lock.yaml
web/manager/package-lock.yaml
web/manager/tsconfig*.json
web/manager/vite.config.ts
web/manager/postcss.config.js
web/manager/tailwind.config.js

# Scripts (development only)
scripts/
